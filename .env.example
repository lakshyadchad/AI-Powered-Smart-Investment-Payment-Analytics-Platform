# Copy this file to .env and edit values as needed.

# Default is local SQLite so the app works immediately.
# For MySQL use:
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/smart_finance
DATABASE_URL=sqlite:///./smart_finance.db

APP_NAME=AI-Powered Smart Investment & Payment Analytics Platform
DEFAULT_CURRENCY=INR
ENABLE_LIVE_MARKET_DATA=false
